# Cloudflare Wrangler system environment variables
# Copy to .env and fill local values. .env is git-ignored.
# Docs: https://developers.cloudflare.com/workers/wrangler/system-environment-variables/

# Required when account_id is intentionally omitted from wrangler.jsonc.
CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account-id"

# Optional for token-based deploy/CI.
# For local interactive deploy, you may use `wrangler login` instead.
# CLOUDFLARE_API_TOKEN="your-cloudflare-api-token"
